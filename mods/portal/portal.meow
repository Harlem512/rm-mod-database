--   self.x + 8 - self.dx * 16,
--   self.y + 8 - self.dy * 16,
--   true
-- )

-- draw_rectangle(
--   self.x - self.dx * 22 + self.dy * 12,
--   self.y - self.dy * 22 + self.dx * 10,
--   self.x + self.dx * 22 + self.dy * 10,
--   self.y + self.dy * 22 + self.dx * 12,
--   false
-- )

with oplayer {
  global.deb.log(self.x)
}

draw_set_color(col)

matrix_stack_pop()
matrix_set(matrix_world, old_matrix)
